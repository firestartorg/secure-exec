{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build:bridge": {
      "outputs": ["dist/bridge.js"]
    },
    "build:polyfills": {},
    "build:isolate-runtime": {},
    "build:generated": {
      "dependsOn": ["build:bridge", "build:polyfills", "build:isolate-runtime"]
    },
    "build:wasm": {
      "dependsOn": [],
      "inputs": ["wasmvm/**/*.rs", "wasmvm/Cargo.toml", "wasmvm/patches/**"],
      "outputs": ["wasmvm/target/wasm32-wasip1/release/multicall.opt.wasm"]
    },
    "build": {
      "dependsOn": ["^build", "build:generated"],
      "outputs": ["dist/**"]
    },
    "check-types": {
      "dependsOn": ["^build", "build:generated"]
    },
    "test": {
      "dependsOn": ["^build", "build:generated"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
